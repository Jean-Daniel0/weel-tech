# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ANTHROPIC_API_KEY: Optional fallback key for Anthropic Claude models.
ANTHROPIC_API_KEY=""

# OPENAI_API_KEY: Optional fallback key for OpenAI GPT models.
OPENAI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: URL of your Supabase project (e.g. https://xyz.supabase.co)
VITE_SUPABASE_URL=""

# SUPABASE_ANON_KEY: Anonymous public API key of your Supabase project
VITE_SUPABASE_ANON_KEY=""

# STRIPE_SECRET_KEY: Secret API key for Stripe payment processing
STRIPE_SECRET_KEY=""

# STRIPE_WEBHOOK_SECRET: Secret key for verifying Stripe webhook signatures
STRIPE_WEBHOOK_SECRET=""

# BAZIK_API_KEY: Secret API token for Bazik transfer integration
BAZIK_API_KEY=""

# BAZIK_API_URL: API base URL for Bazik (e.g. https://api.bazik.io/v1)
BAZIK_API_URL=""

# DYNADOT_API_KEY: Secret key for Dynadot domain search and purchase API
DYNADOT_API_KEY=""

# CLOUDFLARE_API_KEY: Cloudflare API key / token for custom domain association
CLOUDFLARE_API_KEY=""

# CLOUDFLARE_ACCOUNT_ID: Cloudflare account ID
CLOUDFLARE_ACCOUNT_ID=""
